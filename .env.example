DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Europe/Moscow

# Option 1: PostgreSQL through DATABASE_URL.
# Docker compose from this repository exposes PostgreSQL on port 15432.
DATABASE_URL=postgres://smart_user:smart_password@127.0.0.1:15432/smart_library

# Option 2: PostgreSQL through separate variables if DATABASE_URL is empty.
POSTGRES_DB=smart_library
POSTGRES_USER=smart_user
POSTGRES_PASSWORD=smart_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=15432

# Optional local fallback without PostgreSQL.
USE_SQLITE=False

# Redis / Celery.
# Docker compose from this repository exposes Redis on port 16379.
REDIS_URL=redis://127.0.0.1:16379/0
CELERY_BROKER_URL=redis://127.0.0.1:16379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:16379/0
CELERY_TASK_ALWAYS_EAGER=False

# LLM / Ollama.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_MODEL_HIGH=qwen2.5:1.5b
OLLAMA_MODEL_FAST=qwen2.5:1.5b
OLLAMA_MODEL_FALLBACK=qwen2.5:1.5b
OLLAMA_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_ENABLE_FALLBACK=True
LLM_CACHE_TTL_SECONDS=2592000
LLM_MAX_CALLS_PER_BOOK=220
LLM_MAX_CALLS_PER_CHAPTER=40
LLM_MAX_CHUNKS_PER_SECTION=4
LLM_MAX_INPUT_CHARS=8000

# Analysis defaults.
BOOK_ANALYSIS_MODE=llm_thought_chain
THOUGHT_SAME_BLOCK_THRESHOLD=0.65
THOUGHT_RELATION_THRESHOLD=0.65
THOUGHT_BLOCK_MEMBERSHIP_THRESHOLD=0.70
THOUGHT_CHAIN_DRY_RUN_MAX_PAIRS=60
THOUGHT_CHAIN_EXISTING_BLOCK_LIMIT=30
# Optional safety limits for very large thought-chain runs. 0 means no limit.
THOUGHT_CHAIN_MAX_SENTENCES=0
THOUGHT_CHAIN_MAX_PAIRS=0
THOUGHT_CHAIN_SKIP_PAIRWISE=false
THOUGHT_CHAIN_SKIP_GLOBAL_BLOCKS=false
BOOK_STUCK_TIMEOUT_MINUTES=90
BLOCK_MIN_WORDS=260
BLOCK_TARGET_WORDS=760
BLOCK_MAX_WORDS=1300

# Vector/RAG settings.
VECTOR_STORE=chroma
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Web/API.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DEFAULT_FROM_EMAIL=noreply@local.local

# Telegram bot token. Put the real token only in .env, never in git.
TELEGRAM_BOT_TOKEN=your_token_here
