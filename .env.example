DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Europe/Moscow

DATABASE_URL=postgres://postgres:postgres@localhost:5432/intelligent_library
POSTGRES_DB=smart_library
POSTGRES_USER=smart_user
POSTGRES_PASSWORD=smart_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_RETRY_COOLDOWN_SECONDS=45
OLLAMA_TIMEOUT_COOLDOWN_SECONDS=60
OLLAMA_MAX_TOKENS_TEXT=140
OLLAMA_MAX_TOKENS_JSON=320

VECTOR_STORE=chroma
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DISABLE_ST=0
BLOCK_MIN_WORDS=260
BLOCK_TARGET_WORDS=760
BLOCK_MAX_WORDS=1300
BLOCK_LLM_BOUNDARY_ENABLED=1
BLOCK_LLM_BOUNDARY_MAX_CALLS=6

CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DEFAULT_FROM_EMAIL=noreply@local.local
TELEGRAM_BOT_TOKEN=your_token_here

# Optional local fallback without external services:
# USE_SQLITE=True
# CELERY_TASK_ALWAYS_EAGER=True
